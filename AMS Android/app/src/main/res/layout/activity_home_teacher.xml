<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/slate_50">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/primary"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teacher Dashboard"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back!"
            android:textColor="@color/primary_light"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="7"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="true">

            <!-- Buttons re-mapped to preserve IDs so Java code doesn't break -->
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button27"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Subject Planner"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button24"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="View Timetable"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button28"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="View Students"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button29"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Assignments"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button35"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Attendance"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button31"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Manage Exam"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button30"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Internal Marks"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button50"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Exam Question"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button32"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Study Materials"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button37"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Chat"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button33"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Feedback"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button34"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Survey"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button36"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="View Profile"
                android:textColor="@color/primary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button23"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Logout"
                android:backgroundTint="@color/danger"
                android:textColor="@color/white" />

        </GridLayout>
    </ScrollView>
</LinearLayout>

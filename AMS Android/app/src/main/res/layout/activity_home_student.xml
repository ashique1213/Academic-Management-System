<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/slate_50">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/secondary"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Dashboard"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back, ready to learn?"
            android:textColor="@color/slate_200"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="8"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button15"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Subject Plan"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button38"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Subjects"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button39"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Timetable"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button40"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Assignments"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button42"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Exams"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button41"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Internal Marks"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button45"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Attendance"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button43"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Materials"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button46"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Announcements"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button47"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Fee Details"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button48"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Chat"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button44"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Feedback"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button19"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Survey"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button49"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Profile"
                android:textColor="@color/secondary_dark"
                app:strokeColor="@color/slate_300" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button20"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="2"
                android:layout_margin="8dp"
                android:padding="16dp"
                android:text="Logout"
                android:backgroundTint="@color/danger"
                android:textColor="@color/white" />

        </GridLayout>
    </ScrollView>
</LinearLayout>
